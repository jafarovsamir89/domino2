{
  "name": "domino2",
  "version": "1.0.0",
  "description": "",
  "main": "index.html",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "sync:www": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-www.ps1",
    "cap:copy": "npm run sync:www && npx cap copy android",
    "apk:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/build-apk.ps1",
    "platform:db": "docker compose -f docker-compose.platform.yml up -d",
    "platform:api:dev": "npm run dev -w @domino2/api",
    "platform:admin:dev": "npm run dev -w @domino2/admin",
    "platform:prisma:generate": "npm run generate -w @domino2/db",
    "platform:prisma:validate": "cd packages/db && npx prisma validate --schema prisma/schema.prisma",
    "platform:promote-admin": "node packages/db/scripts/promote-user-to-admin.mjs",
    "deploy:gcloud": "powershell -ExecutionPolicy Bypass -File ./scripts/gcloud/update-server.ps1",
    "deploy:gcloud:platform": "powershell -ExecutionPolicy Bypass -File ./scripts/gcloud/update-server.ps1 -PlatformOnly",
    "deploy:gcloud:legacy": "powershell -ExecutionPolicy Bypass -File ./scripts/gcloud/update-server.ps1 -LegacyOnly",
    "deploy:gcloud:git": "powershell -ExecutionPolicy Bypass -File ./scripts/gcloud/deploy-from-ide.ps1",
    "deploy:gcloud:google": "powershell -ExecutionPolicy Bypass -File ./scripts/gcloud/import-google-oauth.ps1",
    "check": "node scripts/check-mojibake.mjs && node --check js/account.js && node --check js/app.js && node --check js/network.js && node --check www/js/app.js && node --check www/js/renderer.js && node --check www/js/board.js && node --check www/js/ai.js && node --check www/js/model.js && node --check www/js/sounds.js && node --check www/js/network.js",
    "test": "npm run check && npm --prefix server test && npm --prefix apps/api test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@colyseus/sdk": "^0.17.42",
    "colyseus.js": "^0.16.22",
    "gsap": "^3.15.0"
  }
}
