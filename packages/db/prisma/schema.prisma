generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  open
  resolved
  rejected
}

enum PaymentStatus {
  pending
  requires_action
  paid
  failed
  refunded
  canceled
}

enum CoinLedgerType {
  grant
  spend
  reserve
  release
  consume
  payout
  refund
  daily_bonus
  quest_reward
  achievement_reward
  tournament_entry
  tournament_prize
  admin_adjustment
  shop_purchase
  ad_reward
  gift_send
  gift_exchange
}

enum CoinStakeStatus {
  reserved
  settled
  refunded
  canceled
}

enum CoinTournamentEntryStatus {
  registered
  active
  eliminated
  refunded
  paid
}

enum FriendConnectionStatus {
  pending
  accepted
  rejected
  blocked
}

enum RoomInvitationStatus {
  pending
  accepted
  declined
  expired
  revoked
}

model User {
  id              String          @id
  name            String
  email           String          @unique
  emailVerified   Boolean         @default(false)
  image           String?
  role            String?         @default("player")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  sessions        Session[]
  accounts        Account[]
  player          Player?
  createdBans     PlayerBan[]     @relation("BanCreatedBy")
  revokedBans     PlayerBan[]     @relation("BanRevokedBy")
  resolvedReports PlayerReport[]  @relation("ReportResolvedBy")
  auditLogs       AdminAuditLog[]
  systemAuditLogs SystemAuditLog[] @relation("SystemAuditActorUser")
  coinLedgerEntries CoinLedgerEntry[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Player {
  id            String             @id @default(cuid())
  legacyUserId  String?            @unique
  legacyNameKey String?
  userId        String?            @unique
  displayName   String
  avatarSeed    String?
  avatarUrl     String?
  tableSkinKey  String?
  isGuest       Boolean            @default(false)
  language      String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  stats         PlayerStats?
  matches       MatchParticipant[]
  reportsIn     PlayerReport[]     @relation("ReportTarget")
  reportsBy     PlayerReport[]     @relation("ReportAuthor")
  bans          PlayerBan[]
  wallet        CoinWallet?
  ledgerEntries CoinLedgerEntry[]
  dailyClaims   CoinDailyBonusClaim[]
  questProgress CoinQuestProgress[]
  matchStakes   CoinMatchStake[]
  tournamentEntries CoinTournamentEntry[]
  orders        Order[]
  entitlements  PlayerEntitlement[]
  friendRequestsSent FriendConnection[] @relation("FriendRequestSender")
  friendRequestsReceived FriendConnection[] @relation("FriendRequestRecipient")
  sentDirectMessages DirectMessage[] @relation("SentDirectMessages")
  receivedDirectMessages DirectMessage[] @relation("ReceivedDirectMessages")
  roomInvitesSent RoomInvitation[] @relation("RoomInviteSender")
  roomInvitesReceived RoomInvitation[] @relation("RoomInviteRecipient")
  giftsSent GiftTransaction[] @relation("GiftSender")
  giftsReceived GiftTransaction[] @relation("GiftRecipient")
  giftInventory PlayerGiftInventory[]
  systemAuditLogs SystemAuditLog[] @relation("SystemAuditActorPlayer")
}

model PlayerStats {
  id            String @id @default(cuid())
  playerId       String @unique
  rating         Int    @default(1000)
  points         Int    @default(0)
  wins           Int    @default(0)
  losses         Int    @default(0)
  draws          Int    @default(0)
  matchesPlayed  Int    @default(0)
  currentStreak  Int    @default(0)
  bestStreak     Int    @default(0)
  player         Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([rating, matchesPlayed, wins])
}

model CoinEconomyConfig {
  id                  String   @id @default(cuid())
  key                 String   @unique
  dailyBaseAmount     Int      @default(25)
  dailyStreakBonus    Int      @default(5)
  dailyMaxStreak      Int      @default(7)
  dailyClaimCooldown  Int      @default(20)
  matchCommissionBps  Int      @default(500)
  tournamentCommissionBps Int   @default(1000)
  adRewardAmount      Int      @default(10)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
}

model CoinWallet {
  id             String   @id @default(cuid())
  playerId       String   @unique
  balance        Int      @default(0)
  reserved       Int      @default(0)
  lifetimeEarned  Int      @default(0)
  lifetimeSpent   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  player         Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
}

model CoinLedgerEntry {
  id              String          @id @default(cuid())
  playerId        String
  type            CoinLedgerType
  amount          Int
  balanceBefore   Int
  balanceAfter    Int
  reservedBefore  Int             @default(0)
  reservedAfter   Int             @default(0)
  referenceType   String
  referenceId     String
  idempotencyKey  String?         @unique
  note            String?
  payloadJson     Json?
  createdByUserId String?
  createdAt       DateTime        @default(now())
  player          Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdByUser   User?           @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([playerId, createdAt])
  @@index([referenceType, referenceId])
}

model CoinDailyBonusClaim {
  id          String   @id @default(cuid())
  playerId    String
  claimDate   String
  streakDay   Int      @default(1)
  amount      Int
  createdAt   DateTime @default(now())
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, claimDate])
}

model CoinQuest {
  id            String   @id @default(cuid())
  key           String   @unique
  title         String
  description   String?
  rewardAmount  Int      @default(0)
  maxProgress   Int      @default(1)
  period        String   @default("once")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  progress      CoinQuestProgress[]
}

model CoinQuestProgress {
  id           String   @id @default(cuid())
  playerId     String
  questId      String
  progress     Int      @default(0)
  state        String   @default("active")
  claimedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  quest        CoinQuest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([playerId, questId])
}

model CoinStakeTable {
  id            String   @id @default(cuid())
  key           String   @unique
  title         String
  stakeAmount   Int      @default(0)
  commissionBps Int      @default(500)
  isFree        Boolean  @default(false)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stakes        CoinMatchStake[]
}

model CoinMatchStake {
  id              String         @id @default(cuid())
  roomId          String
  matchId         String?
  playerId        String
  stakeTableId    String
  stakeAmount     Int
  commissionBps   Int
  commissionAmount Int           @default(0)
  status          CoinStakeStatus @default(reserved)
  reservedAt      DateTime       @default(now())
  settledAt       DateTime?
  refundedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  player          Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  stakeTable      CoinStakeTable @relation(fields: [stakeTableId], references: [id], onDelete: Cascade)

  @@unique([roomId, playerId, stakeTableId])
  @@index([roomId, status])
  @@index([matchId])
}

model CoinTournament {
  id                 String   @id @default(cuid())
  key                String   @unique
  title              String
  description        String?
  entryFee           Int      @default(0)
  prizePool          Int      @default(0)
  commissionBps      Int      @default(1000)
  startsAt           DateTime?
  endsAt             DateTime?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  entries            CoinTournamentEntry[]
}

model CoinTournamentEntry {
  id            String                 @id @default(cuid())
  tournamentId  String
  playerId      String
  status        CoinTournamentEntryStatus @default(registered)
  entryFee      Int                    @default(0)
  payoutAmount  Int                    @default(0)
  joinedAt      DateTime               @default(now())
  settledAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  player        Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade)
  tournament    CoinTournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
}

model Match {
  id           String             @id @default(cuid())
  mode         String
  isTeamMode   Boolean            @default(false)
  roomId       String?
  winnerKey    String?
  result       String?
  totalPoints  Int                @default(0)
  createdAt    DateTime           @default(now())
  participants MatchParticipant[]
  reports      PlayerReport[]
}

model MatchParticipant {
  id                  String   @id @default(cuid())
  matchId             String
  playerId            String?
  displayNameSnapshot String
  teamIndex           Int?
  winnerKey           String?
  result              String?
  points              Int      @default(0)
  roundWins           Int      @default(0)
  ratingBefore        Int?
  ratingDelta         Int?
  ratingAfter         Int?
  isBot               Boolean  @default(false)
  match               Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player              Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@unique([matchId, playerId])
}

model FriendConnection {
  id                   String                @id @default(cuid())
  requesterPlayerId     String
  addresseePlayerId     String
  status               FriendConnectionStatus @default(pending)
  note                 String?
  respondedAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  requester            Player                @relation("FriendRequestSender", fields: [requesterPlayerId], references: [id], onDelete: Cascade)
  addressee            Player                @relation("FriendRequestRecipient", fields: [addresseePlayerId], references: [id], onDelete: Cascade)

  @@unique([requesterPlayerId, addresseePlayerId])
  @@index([requesterPlayerId, status])
  @@index([addresseePlayerId, status])
}

model RoomInvitation {
  id                 String              @id @default(cuid())
  roomId             String
  roomCode           String?
  roomMode           String
  isTeamMode         Boolean             @default(false)
  stakeKey           String?
  stakeAmount        Int                 @default(0)
  humanSeats         Int                 @default(0)
  totalPlayers       Int                 @default(0)
  inviterPlayerId    String
  inviteePlayerId    String
  status             RoomInvitationStatus @default(pending)
  note               String?
  payloadJson        Json?
  expiresAt          DateTime?
  respondedAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inviter            Player              @relation("RoomInviteSender", fields: [inviterPlayerId], references: [id], onDelete: Cascade)
  invitee            Player              @relation("RoomInviteRecipient", fields: [inviteePlayerId], references: [id], onDelete: Cascade)

  @@index([inviteePlayerId, status, createdAt])
  @@index([inviterPlayerId, status, createdAt])
  @@index([roomId, status])
  @@index([roomCode, status])
}

model DirectMessage {
  id               String   @id @default(cuid())
  senderPlayerId   String
  receiverPlayerId String
  text             String
  createdAt        DateTime @default(now())
  readAt           DateTime?

  sender           Player   @relation("SentDirectMessages", fields: [senderPlayerId], references: [id], onDelete: Cascade)
  receiver         Player   @relation("ReceivedDirectMessages", fields: [receiverPlayerId], references: [id], onDelete: Cascade)

  @@index([senderPlayerId, receiverPlayerId, createdAt])
  @@index([receiverPlayerId, senderPlayerId, createdAt])
}

model GiftCatalog {
  id             String                @id @default(cuid())
  key            String                @unique
  name           String
  description    String?
  assetKey       String                @unique
  coinCost       Int                   @default(100)
  exchangeRateBps Int                   @default(7000)
  rarity         String                @default("common")
  sortOrder      Int                   @default(0)
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  inventories    PlayerGiftInventory[]
  transactions   GiftTransaction[]
}

model PlayerGiftInventory {
  id              String      @id @default(cuid())
  playerId        String
  giftCatalogId   String
  quantity        Int         @default(0)
  receivedCount   Int         @default(0)
  sentCount       Int         @default(0)
  exchangedCount  Int         @default(0)
  lastReceivedAt  DateTime?
  lastSentAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  player          Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  catalog         GiftCatalog @relation(fields: [giftCatalogId], references: [id], onDelete: Cascade)

  @@unique([playerId, giftCatalogId])
  @@index([playerId, updatedAt])
}

model GiftTransaction {
  id                String      @id @default(cuid())
  senderPlayerId    String
  recipientPlayerId  String
  giftCatalogId     String
  giftKeySnapshot   String
  giftNameSnapshot  String
  assetKeySnapshot  String
  coinCost          Int
  exchangeValue     Int
  contextType       String      @default("match")
  contextId         String?
  note              String?
  status            String      @default("sent")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  sender            Player      @relation("GiftSender", fields: [senderPlayerId], references: [id], onDelete: Cascade)
  recipient         Player      @relation("GiftRecipient", fields: [recipientPlayerId], references: [id], onDelete: Cascade)
  catalog           GiftCatalog @relation(fields: [giftCatalogId], references: [id], onDelete: Restrict)

  @@index([recipientPlayerId, createdAt])
  @@index([senderPlayerId, createdAt])
  @@index([giftCatalogId, createdAt])
}

model PlayerBan {
  id              String   @id @default(cuid())
  playerId        String
  reason          String
  expiresAt       DateTime?
  createdByUserId String?
  revokedAt       DateTime?
  revokedByUserId String?
  createdAt       DateTime @default(now())
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdByUser   User?    @relation("BanCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  revokedByUser   User?    @relation("BanRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
}

model PlayerReport {
  id               String       @id @default(cuid())
  reporterPlayerId String
  targetPlayerId   String
  matchId          String?
  reason           String
  status           ReportStatus @default(open)
  createdAt        DateTime     @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  reporter         Player       @relation("ReportAuthor", fields: [reporterPlayerId], references: [id], onDelete: Cascade)
  target           Player       @relation("ReportTarget", fields: [targetPlayerId], references: [id], onDelete: Cascade)
  match            Match?       @relation(fields: [matchId], references: [id], onDelete: SetNull)
  resolvedByUser   User?        @relation("ReportResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  entityType  String
  entityId    String
  payloadJson Json?
  createdAt   DateTime @default(now())
  adminUser   User     @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
}

model SystemAuditLog {
  id           String   @id @default(cuid())
  actorType    String   @default("system")
  actorUserId  String?
  actorPlayerId String?
  action       String
  entityType   String
  entityId     String
  payloadJson  Json?
  createdAt    DateTime @default(now())
  actorUser    User?    @relation("SystemAuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorPlayer  Player?  @relation("SystemAuditActorPlayer", fields: [actorPlayerId], references: [id], onDelete: SetNull)

  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([actorPlayerId, createdAt])
}

model CatalogProduct {
  id          String         @id @default(cuid())
  key         String         @unique
  name        String
  description String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  prices      CatalogPrice[]
  orders      Order[]
}

model CatalogPrice {
  id          String   @id @default(cuid())
  productId   String
  currency    String
  amountMinor Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  product     CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders      Order[]
}

model Order {
  id          String        @id @default(cuid())
  playerId    String
  productId   String
  priceId     String
  status      PaymentStatus @default(pending)
  externalRef String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  player      Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  product     CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  price       CatalogPrice  @relation(fields: [priceId], references: [id], onDelete: Cascade)
  payments    Payment[]
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  provider          String
  providerPaymentId String?
  status            PaymentStatus @default(pending)
  amountMinor       Int
  currency          String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model PaymentEvent {
  id              String   @id @default(cuid())
  provider        String
  providerEventId String   @unique
  type            String
  payloadJson     Json
  createdAt       DateTime @default(now())
}

model PlayerEntitlement {
  id         String   @id @default(cuid())
  playerId   String
  productKey String
  quantity   Int      @default(1)
  grantedAt  DateTime @default(now())
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, productKey])
}
